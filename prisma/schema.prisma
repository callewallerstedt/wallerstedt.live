generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  path      String
  label     String   @default("")
  href      String   @default("")
  title     String   @default("")
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([path, createdAt])
}
